{
  "name": "web",
  "private": true,
  "version": "2.9.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "generate-routes": "npx @tanstack/router-cli generate",
    "typecheck": "npm run generate-routes && tsc -b --noEmit",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage .turbo *.tsbuildinfo src/routeTree.gen.ts"
  },
